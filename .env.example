# Core
PORT=5001
MONGODB_URI=mongodb+srv://user:pass@cluster/db
JWT_SECRET=change-me

# Phase 5 / Plan C — split processes (Render: set per service)
# API service:  RUN_API=true  RUN_CRONS=false RUN_WORKERS=false
# Cron service: RUN_API=false RUN_CRONS=true  RUN_WORKERS=true
RUN_API=true
RUN_CRONS=false
RUN_WORKERS=false

# Mongo pool + cron budget (see docs/CRON_SCHEDULE.md)
MONGODB_MAX_POOL_SIZE=25
MONGODB_WAIT_QUEUE_TIMEOUT_MS=12000
CRON_USE_COORDINATOR=true
CRON_MONGO_CONCURRENCY=3
# CRON_MONGO_BUDGET=false  # disable only for debugging

# Startup / crons
DEFER_STARTUP_HEAVY_MS=60000
FLOW_RESUMPTION_EVERY_MINUTE=false
CRON_ENABLE_AMAZON_SYNC=false
CRON_ENABLE_AB_WINNER=false
ENABLE_SELF_PING=false
BOOTSTRAP_CACHE_TTL_SEC=45

# WhatsApp inbound (Plan D — instant "hi" response)
INBOUND_QUEUE_DEBOUNCE_MS=300
INBOUND_QUEUE_FIRST_FLUSH_MS=0
AI_CALL_TIMEOUT_MS=5000
DUAL_BRAIN_BUDGET_MS=22000
FLOW_GRAPH_CACHE_TTL_SEC=300
FLOW_PREWARM=true

# Observability
PERF_LOGGING=true
SLOW_REQUEST_MS=5000
METRICS_SECRET=

# Optional production URLs
SERVER_URL=
RENDER_EXTERNAL_URL=
