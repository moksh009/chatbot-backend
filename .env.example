# TopEdge Backend — environment template (June 2026)
# Copy to .env and fill secrets. Never commit .env.

# ── HTTP ─────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:5001

# ── Data stores ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/topedge
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me-in-production
# 32+ char secret for encrypted Client fields (whatsapp tokens, etc.)
FIELD_ENCRYPTION_KEY=change-me-32-chars-minimum-required
# Legacy alias still supported:
# ENCRYPTION_KEY=

# ── Process split (Phase 2 — see scripts/start-api-*.sh) ───────────
# Local dev: terminal 1 → ./scripts/start-api-dev.sh
#            terminal 2 → ./scripts/start-crons-only.sh
#
# Production API (api.topedgeai.com):
#   RUN_API=true  RUN_CRONS=false  RUN_WORKERS=false
#   EMAIL_SCHEDULE_TICK_ON_API=true
#   ABANDON_CART_TICK_ON_API=false
#
# Production worker (crons + BullMQ):
#   RUN_API=false  RUN_CRONS=true  RUN_WORKERS=true
#   CHATBOT_PROCESS_ROLE=worker
#
# Single-process (legacy Contabo all-in-one): all RUN_*=true + SUPPRESS_SPLIT_DEPLOY_WARN=true
#   Prefer split deploy — boot warns when API+crons share one process (Mongo pool contention).

RUN_API=true
RUN_CRONS=false
RUN_WORKERS=false
EMAIL_SCHEDULE_TICK_ON_API=true
ABANDON_CART_TICK_ON_API=false
SUPPRESS_SPLIT_DEPLOY_WARN=true

# ── Lifecycle automations ──────────────────────────────────────────────
SEND_SIGNUP_WELCOME_EMAIL=true
SEND_SIGNUP_WELCOME_WHATSAPP=true
SEND_BILLING_REMINDER_7D=true
SEND_PAYMENT_SUCCESS_NOTIFY=true
SEND_POST_PURCHASE_REVIEW_14D=true
# Optional until Phase 4 platform WABA setup is complete.
# TOPEDGE_SYSTEM_CLIENT_ID=topedge_platform
TOPEDGE_SYSTEM_CLIENT_ID=topedge_platform_support
# TOPEDGE_SYSTEM_WABA_ID=
# TOPEDGE_SYSTEM_WABA_PHONE_NUMBER_ID=
# TOPEDGE_SYSTEM_WABA_ACCESS_TOKEN=
# TOPEDGE_WELCOME_TEMPLATE_NAME=topedge_platform_welcome_utility_v1
# TOPEDGE_BILLING_REMINDER_TEMPLATE_NAME=topedge_billing_reminder_7d_v1
# TOPEDGE_PAYMENT_SUCCESS_TEMPLATE_NAME=topedge_payment_success_v1
# TOPEDGE_POST_PURCHASE_REVIEW_TEMPLATE_NAME=topedge_review_14d_v1
# PLATFORM_REVIEW_TOKEN_SECRET=
# POST_PURCHASE_SURVEY_BASE_URL=https://dash.topedgeai.com
# PUBLIC_REVIEW_URL=
# MARKETING_DESK_MAX_CONTACTS=500
# TOPEDGE_SUPPORT_WHATSAPP=+919313045439
# DFY_BOOKING_URL=

# ── Feature bundle flags (optional — enable on staging first) ────────
# Pair each VITE_* flag on dash with matching FEATURE_* on API (see workspaceFeatures.js).
#
# Tier 1 — cold start `/` (target ≤6 HTTP in first 2.5s; use dev [ColdStart] console):
#   FEATURE_WORKSPACE_SHELL=true       + VITE_FEATURE_WORKSPACE_SHELL=true
#   FEATURE_DASHBOARD_BUNDLE=true      + VITE_FEATURE_DASHBOARD_BUNDLE=true
#
# Tier 2 — per-hub (after Tier 1 measured on staging):
#   FEATURE_META_WORKSPACE_SHELL=true  + VITE_FEATURE_META_WORKSPACE_SHELL=true
#   FEATURE_ANALYTICS_WORKSPACE_BUNDLE=true + VITE_FEATURE_ANALYTICS_WORKSPACE_BUNDLE=true
#   FEATURE_ORDER_MESSAGES_WORKSPACE_BUNDLE=true + VITE_FEATURE_ORDER_MESSAGES_WORKSPACE_BUNDLE=true
#   FEATURE_INBOX_WORKSPACE_BUNDLE=true + VITE_FEATURE_INBOX_WORKSPACE_BUNDLE=true
#
# FEATURE_WORKSPACE_SHELL=true
# FEATURE_DASHBOARD_BUNDLE=true
# FEATURE_META_WORKSPACE_SHELL=true
# FEATURE_ANALYTICS_WORKSPACE_BUNDLE=true
# FEATURE_ORDER_MESSAGES_WORKSPACE_BUNDLE=true
# FEATURE_INBOX_WORKSPACE_BUNDLE=true

# ── Observability (Phase 5) ──────────────────────────────────────────
# PERF_LOGGING=true          # structured route/cron timings (dev on by default)
# DISPATCH_EVENT_LOG=verbose # log skip paths for order/cart/campaign/sequence/email
# PIXEL_EVENT_LOG=verbose    # log checkout pixel ingest outcomes (all tenants)
# SLOW_REQUEST_LOG=true      # log /api/* slower than 2s (dev on by default)
# SLOW_REQUEST_LOG=false     # disable slow-request warnings in dev
# SENTRY_DSN=                # enables top-route performance transactions (Phase 5.2)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Commerce automations (Order Messages) ───────────────────────────
# When true, legacy nicheData template map + dispatchOrderStatusAutomation are
# disabled globally — only SAC sys_* rules (processOrderStatusAutomations) send.
# Per-tenant: tenants with active sys_* order_notification rules skip legacy automatically.
# Run scripts/migrateRetiredOrderMessageRules.js before enabling in production.
# COMMERCE_CANONICAL_ONLY=true

# Hours after first cart WhatsApp message to credit recovery revenue (default 24).
# CART_RECOVERY_ATTRIBUTION_HOURS=24

# ── Follow-up sequences & campaigns (workers) ───────────────────────
# PHASE3_SEQUENCE_CONCURRENCY=100
# PHASE3_CAMPAIGN_CONCURRENCY=100
# PHASE3_DISPATCH_ENABLED=true

# ── WhatsApp multi-tenant safety ─────────────────────────────────────
# WHATSAPP_ALLOW_GLOBAL_FALLBACK=false  # default: never send from platform env token
