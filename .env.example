# Core
PORT=5001

# Local dev — API rate limits are OFF when NODE_ENV=development (see enterpriseLimits.js).
# Set ENFORCE_API_RATE_LIMIT=true or ENFORCE_TENANT_RATE_LIMIT=true to test prod limits locally.
# API_RATE_LIMIT_MAX=50000
MONGODB_URI=mongodb+srv://user:pass@cluster/db
JWT_SECRET=change-me-use-64-plus-random-chars-in-production
JWT_EXPIRES_IN=7d

# Security (production)
# CORS_STRICT=true
# ALLOWED_ORIGINS=https://your-dashboard.onrender.com
# CORS_ALLOW_ALL=true
# SECURITY_AUDIT_PERSIST=true
# ALLOW_MASTER_TESTER_BYPASS=false
# ALLOW_META_SIGNATURE_BYPASS=false
# ENFORCE_PRODUCTION_SECURITY=true

# Phase 5 / Plan C — split processes (Render: set per service)
# API service:  RUN_API=true  RUN_CRONS=false RUN_WORKERS=false
# Cron service: RUN_API=false RUN_CRONS=true  RUN_WORKERS=true
RUN_API=true
RUN_CRONS=false
RUN_WORKERS=false

# Mongo pool + cron budget (see docs/CRON_SCHEDULE.md)
MONGODB_MAX_POOL_SIZE=25
MONGODB_WAIT_QUEUE_TIMEOUT_MS=12000
CRON_USE_COORDINATOR=true
CRON_MONGO_CONCURRENCY=3
# CRON_MONGO_BUDGET=false  # disable only for debugging

# Startup / crons
DEFER_STARTUP_HEAVY_MS=60000
FLOW_RESUMPTION_EVERY_MINUTE=false
CRON_ENABLE_AMAZON_SYNC=false
CRON_ENABLE_AB_WINNER=false
CRON_ENABLE_AB_TEST_LEGACY=false
CRON_ENABLE_BIRTHDAY=false
ENABLE_SELF_PING=false

# E-commerce vs legacy niche (salon/clinic appointment sequences)
BLOCK_LEGACY_NICHE_AUTOMATION=true
ENABLE_LEGACY_APPOINTMENT_REMINDERS=false
HIDE_DEPRECATED_NICHE_TEMPLATES=false
BOOTSTRAP_CACHE_TTL_SEC=45

# WhatsApp inbound (Plan D — instant "hi" response)
INBOUND_QUEUE_DEBOUNCE_MS=300
INBOUND_QUEUE_FIRST_FLUSH_MS=0
AI_CALL_TIMEOUT_MS=5000
DUAL_BRAIN_BUDGET_MS=22000
FLOW_GRAPH_CACHE_TTL_SEC=300
FLOW_PREWARM=true

# Observability
PERF_LOGGING=true
SLOW_REQUEST_MS=5000
METRICS_SECRET=

# Public API origin (no trailing /api) — webhooks, OAuth callbacks, media URLs
SERVER_URL=https://api.topedgeai.com
PUBLIC_BASE_URL=https://api.topedgeai.com
FRONTEND_URL=https://dash.topedgeai.com
# Legacy alias (same as SERVER_URL — do NOT include /api)
# API_BASE=https://api.topedgeai.com
RENDER_EXTERNAL_URL=

# Google sign-in (dashboard login/signup) — see docs/ops/GOOGLE_OAUTH_SETUP.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: full callback URL (must match Google Console exactly)
# GOOGLE_OAUTH_REDIRECT_URI=https://api.topedgeai.com/api/auth/google/callback
# DEBUG_GOOGLE_OAUTH=1

# ── WhatsApp Embedded Signup v4 ──────────────────────────────────────────────
# Meta App credentials (App Dashboard → App Settings → Basic)
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v21.0
# Webhook verify token — must match the value set in Meta App Dashboard → Webhooks
# Use: openssl rand -hex 32
META_WEBHOOK_VERIFY_TOKEN=
