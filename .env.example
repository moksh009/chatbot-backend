# Copy to .env and fill in values. Never commit real secrets.

PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/topedge

# Public URL of this API (no trailing slash). Required in production for:
# - Wizard logo uploads (/uploads/logos/...)
# - WhatsApp interactive message images
# - Warranty PDF links
PUBLIC_BASE_URL=https://your-api.example.com

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=

# AI
GEMINI_API_KEY=

# Optional: Redis for queues
REDIS_URL=redis://127.0.0.1:6379
