# --- CORE SERVER ---
PORT=5001
MONGODB_URI=mongodb://localhost:27017/top-edge-ai
JWT_SECRET=your_super_secret_jwt_key

# --- REDIS / BULLMQ (Required for Message Aggregation) ---
REDIS_URL=redis://localhost:6379

# --- META / WHATSAPP SECURITY ---
# Your Meta App Secret for HMAC SHA-256 signature verification
META_APP_SECRET=your_meta_app_secret

# --- INFRASTRUCTURE ---
SERVER_URL=https://your-api-url.com
FRONTEND_URL=https://your-dashboard-url.com
