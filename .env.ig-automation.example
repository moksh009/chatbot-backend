# IG Automation Module — Required Environment Variables

# HMAC-SHA256 webhook signature verification
# Used by middleware/verifyMetaSignature.js to validate incoming webhook payloads
META_APP_SECRET=your_meta_app_secret_here

# Meta webhook handshake verification token
# Must match the value configured in your Meta App Dashboard → Webhooks
IG_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Facebook App-level token for oEmbed API calls
# Generate at: https://developers.facebook.com/tools/accesstoken/
FACEBOOK_APP_TOKEN=your_facebook_app_token_here
