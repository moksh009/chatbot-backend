    "load-smoke:k6": "k6 run scripts/load/k6-smoke.js",
    "repair:cart-leads": "node scripts/repair-cart-recovery-leads.js",
    "repair:cart-leads:dry": "node scripts/repair-cart-recovery-leads.js --dry-run",
    "repair:adlead-phones": "node scripts/repair-adlead-phones.js",
    "repair:adlead-phones:dry": "node scripts/repair-adlead-phones.js --dry-run",
    "backfill:campaign-revenue": "node scripts/backfill-campaign-revenue-attribution.js"
