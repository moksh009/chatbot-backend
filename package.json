    "test:commerce-marketing": "node --test tests/messaging/campaignAudienceSnapshot.test.js && npm run test:campaign-attribution",
    "test:phase-e": "node --test tests/commerce/abandonedCartReadiness.test.js tests/commerce/upsertAbandonedCartLead.test.js tests/commerce/cartRecoverySlotSync.test.js tests/commerce/abandonedCartSystemFix.test.js tests/core/notificationServiceAdminAlert.test.js",
